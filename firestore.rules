rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Admin check
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "gauravpatil9262@gmail.com";
    }

    // Approved user check
    function isApproved() {
      return request.auth != null && exists(/databases/$(database)/documents/approved_users/$(request.auth.token.email.lower()));
    }

    // 1. Access Requests Collection
    match /access_requests/{requestId} {
      // Any authenticated user can create a request, but only for themselves
      allow create: if request.auth != null && request.resource.data.email == request.auth.token.email;
      // Only admin can read, update, delete
      allow read, update, delete: if isAdmin();
    }

    // 2. Approved Users Collection
    match /approved_users/{email} {
      // Users can check their own approval status
      allow read: if request.auth != null && request.auth.token.email.lower() == email.lower();
      // Only admin can write to approved users
      allow write: if isAdmin();
    }

    // 3. App Data (Protected Content)
    // Only approved users and admins can access app data
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId && isApproved()) || isAdmin();
      
      match /{document=**} {
        allow read, write: if (request.auth != null && request.auth.uid == userId && isApproved()) || isAdmin();
      }
    }
    
    // Global fallback for admin
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
